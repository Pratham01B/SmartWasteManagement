# Copy this file to .env and fill in your values
# Never commit .env to git

# ── Database (Supabase Pooler) ─────────────────────────────
DATABASE_URL=jdbc:postgresql://aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?sslmode=require&prepareThreshold=0
DATABASE_USERNAME=postgres.your-project-ref
DATABASE_PASSWORD=your-db-password

# ── JWT — generate with: openssl rand -hex 32 ─────────────
JWT_SECRET=your-256-bit-hex-secret

# ── CORS ──────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── Mail (Gmail App Password) ─────────────────────────────
# Enable 2FA on Gmail, then generate an App Password at:
# https://myaccount.google.com/apppasswords
MAIL_USERNAME=your-gmail@gmail.com
MAIL_PASSWORD=xxxx xxxx xxxx xxxx
